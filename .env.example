# Copy to `.env` and fill in values.

# Telegram API (create at https://my.telegram.org/apps)
API_ID=
API_HASH=

# Bot token from @BotFather
BOT_TOKEN=

# Optional legacy session name used when a task has no per-user session.
# Each Telegram user normally gets `rubika_<telegram_user_id>` after `/rubika_connect`.
RUBIKA_SESSION=rubika_session

# Comma-separated Telegram numeric user IDs allowed to use `/admin`
ADMIN_IDS=

# Default split size for large uploads (MB), where applicable
DEFAULT_PART_SIZE_MB=1900

# Reject queued uploads larger than this many MB (Telegram download + zip output).
# Use 0 or leave empty for no limit (helps avoid OOM on small VPS).
MAX_FILE_MB=

# Per-user quotas (SQLite tables user_entitlements + usage_ledger). Set to 1 to disable all limits (only MAX_FILE_MB above may apply).
DISABLE_USAGE_LIMITS=

# Log MD5 checksum per upload attempt (worker logs, adds disk read before Rubika send).
ENABLE_UPLOAD_CHECKSUM=

# Optional HTTP stub payment webhook (see tools/payment_webhook_stub.py).
PAYMENT_WEBHOOK_SECRET=
WEBHOOK_PORT=8787

# Total seconds allowed for one Rubika upload job (all retries). Default 6 hours; raise for multi‑GB ZIPs on slow links.
UPLOAD_TIMEOUT_SECONDS=21600

# Displayed by `/version` and in post-update notifications.
# The installer can bump this on deploy (see APP_BUILD_VERSION in installer.sh).
APP_BUILD_VERSION=dev-local

# If set to 1, true, or yes: skip sending the one-shot “bot updated” message to
# chats listed in `queue/known_chats.json` when the bot starts after a version change.
DISABLE_UPDATE_BROADCAST=
